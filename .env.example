# Copy to .env and fill in. Every provider/toggle is env-driven (brief §8).
# The app boots and all non-model endpoints work even with NOTHING set here.

# ---- App ----
ENVIRONMENT=development
APP_NAME="Smart Grocery Assistant"

# ---- Locale (brief §2: India / INR / GST) ----
CURRENCY=INR
LOCALE=en_IN

# ---- CORS: comma-separated origins allowed to call the API (the frontend URL in prod) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Frontend build-time var (set for the React app, not the backend) ----
# VITE_API_BASE=https://your-backend.onrender.com   # leave unset locally (Vite proxies /api)

# ---- LLM provider (default: gemini; falls back to offline "echo" if no key) ----
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- OCR provider: chained | paddle | easyocr | null ----
# Heavy OCR deps are optional (requirements-vision.txt). Without them, /ocr routes to manual entry.
OCR_PROVIDER=chained
# OCR language code (en | hi | ...). The parser also reads Hindi/Devanagari nutrition labels.
OCR_LANG=en

# ---- Detector: yolo | stub ----
# "yolo" needs ultralytics + a weights file; "stub" returns a low-confidence box (confirm flow).
DETECTOR_PROVIDER=stub
YOLO_WEIGHTS=yolov8n.pt
DETECTOR_CONF_THRESHOLD=0.25
LOW_CONFIDENCE_THRESHOLD=0.40

# ---- Phase 1: barcode / RAG (all have zero-dep fallbacks) ----
BARCODE_PROVIDER=pyzbar            # pyzbar | null
OFF_ENABLED=true                   # Open Food Facts fallback for barcodes not in the seed catalog
OFF_BASE_URL=https://world.openfoodfacts.org
OFF_TIMEOUT=6.0                    # seconds
EMBEDDINGS_PROVIDER=hashing        # sentence_transformers | hashing
VECTOR_STORE=memory               # chroma | memory
RAG_CORPUS_PATH=data/rag/corpus.jsonl
CHROMA_PATH=./.chroma

# ---- Phase 1: auth ----
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7
# Optional Google OAuth (leave blank to disable the OAuth login route)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Data / infra ----
# Local dev default is SQLite; docker-compose overrides this with Postgres.
DATABASE_URL=sqlite:///./grocery.db
REDIS_URL=
SEED_PRODUCTS_CSV=data/seed/products.csv
